# Database Connection URL (SQLite for local, PostgreSQL for Supabase in production)
DATABASE_URL=sqlite:///../database/crime.db

# Supabase Configurations (optional for Python REST API, required for frontend integration)
SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
